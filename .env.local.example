DATABASE_URL=
AUTH_SECRET=

# Vercel Blob (file uploads). If the store was connected via the Vercel
# dashboard, it likely uses OIDC auth instead of a static token: set
# BLOB_STORE_ID (from `vercel env pull`) and run `vercel link` locally so
# VERCEL_OIDC_TOKEN is present. A static BLOB_READ_WRITE_TOKEN also works
# if you have one -- either is sufficient.
BLOB_READ_WRITE_TOKEN=
BLOB_STORE_ID=

# Google OAuth (console.cloud.google.com > APIs & Services > Credentials)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Only this email is allowed to sign in.
ADMIN_EMAIL=
